generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Repository {
  id            Int         @id @default(autoincrement())

  url          String     @unique
  name         String

  updateConfig Json?
  LLM_API      Json?
  ragConfig    Json?

  dataFiles    DataFile[]
}

model DataFile {
  id            Int         @id @default(autoincrement())

  repositoryUrl String
  repository    Repository  @relation(fields: [repositoryUrl], references: [url], onDelete: Cascade)

  remoteUrl     String?
  meta          Json?
  
  createdAt     DateTime?   @default(now())
  chunkedAt     DateTime?
  invalidatedAt DateTime?
  
}


model ChatLog {
  id            Int      @id @default(autoincrement())
  repositoryUrl String?
  endpoint      String?
  
  question      String?
  context       String?
  answer        String?
  
  createdAt     DateTime @default(now())
}



model User {
  id       String  @id @default(uuid())
  email    String  @unique

  repositoryJson  Json?

  password String
  cryptVersion Int @default(0)

  isDeleted Int @default(0)
  createdAt       DateTime? @default(now())



}



model GitlabApiLog {
  id         Int      @id @default(autoincrement())
  endpoint   String
  method     String
  status     Int
  ip         String?
  userAgent  String?
  payload    Json?
  createdAt  DateTime @default(now())
}
