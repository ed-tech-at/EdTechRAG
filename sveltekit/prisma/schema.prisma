generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Repository {
  url          String     @unique
  name         String
  updateConfig Json?
  LLM_API      Json?
  ragConfig    Json?
  dataFiles    DataFile[]
}

model DataFile {
  remoteUrl     String?
  meta          Json?
  createdAt     DateTime?   @default(now())
  repositoryUrl String
  chunkedAt     DateTime?
  invalidatedAt DateTime?
  id            Int         @id @default(autoincrement())
  dataChunks    DataChunk[]
  repository    Repository  @relation(fields: [repositoryUrl], references: [url], onDelete: Cascade)
}

model DataChunk {
  chunkNr        Int?
  content        String?
  embeddingModel String?
  createdAt      DateTime? @default(now())
  embeddedAt     DateTime?
  invalidatedAt  DateTime?
  id             Int       @id @default(autoincrement())
  dataFileId     Int
  dataFile       DataFile  @relation(fields: [dataFileId], references: [id], onDelete: Cascade)
}

model ChatLog {
  question      String?
  context       String?
  answer        String?
  repositoryUrl String?
  endpoint      String?
  createdAt     DateTime @default(now())
  id            Int      @id @default(autoincrement())
}
