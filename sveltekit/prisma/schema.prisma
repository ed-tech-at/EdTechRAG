generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Repository {
  url          String     @unique
  name         String

  updateConfig Json?
  LLM_API      Json?
  ragConfig    Json?

  dataFiles    DataFile[]
}

model DataFile {
  id            Int         @id @default(autoincrement())

  repositoryUrl String
  repository    Repository  @relation(fields: [repositoryUrl], references: [url], onDelete: Cascade)

  remoteUrl     String?
  meta          Json?
  
  createdAt     DateTime?   @default(now())
  chunkedAt     DateTime?
  invalidatedAt DateTime?
  
  dataChunks    DataChunk[]
}

model DataChunk {
  id             Int       @id @default(autoincrement())
  chunkNr        Int?
  content        String?
  
  dataFileId     Int
  dataFile       DataFile  @relation(fields: [dataFileId], references: [id], onDelete: Cascade)
  
  embeddingModel String?
  
  createdAt      DateTime? @default(now())
  embeddedAt     DateTime?
  invalidatedAt  DateTime?
}

model ChatLog {
  id            Int      @id @default(autoincrement())
  repositoryUrl String?
  endpoint      String?
  
  question      String?
  context       String?
  answer        String?
  
  createdAt     DateTime @default(now())
}

model vector1536 {
  id            Int    @id   @default(autoincrement())
  dataChunkId   Int
  
  repositoryUrl String?
  createdAt     DateTime  @default(now())
  invalidatedAt DateTime?
}
